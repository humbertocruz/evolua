generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Movie {
  id Int @id @default(autoincrement())
  title String 
  overview String 
  genre String 
  poster_path String 
  backdrop_path String 
  release_date String 
  vote_average Int 
}
