{
  "name": "appware",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "description": "Appware monorepo",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "prisma:generate:web": "bun --filter @evolua/web prisma:generate",
    "dev:web": "bun --filter @evolua/web dev",
    "build:web": "bun run prisma:generate:web && bun --filter @evolua/web build",
    "lint:web": "bun --filter @evolua/web lint",
    "publish": "bash scripts/publish.sh"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "esbuild": "^0.27.4",
    "rollup": "^4.60.0",
    "turbo": "^2.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
