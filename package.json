{
  "name": "evolua",
  "private": true,
  "version": "0.1.0",
  "description": "Evolu[a] monorepo",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "prisma:generate:web": "bun --filter @evolua/web prisma:generate",
    "dev:web": "bun --filter @evolua/web dev",
    "build:web": "bun run prisma:generate:web && bun --filter @evolua/web build",
    "lint:web": "bun --filter @evolua/web lint"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}