{
  "project": {
    "name": "Evolua Movie App",
    "version": "0.2.0",
    "description": "A futuristic movie dashboard powered by Evolua AI."
  },
  "theme": {
    "colors": {
      "primary": "pink-500",
      "background": "zinc-950",
      "surface": "zinc-900",
      "text": "zinc-100"
    },
    "style": "glassmorphism"
  },
  "data": {
    "entities": [
      {
        "name": "Movie",
        "fields": [
          { "name": "id", "type": "number", "primary": true },
          { "name": "title", "type": "string" },
          { "name": "overview", "type": "string" },
          { "name": "genre", "type": "string" },
          { "name": "poster_path", "type": "string" },
          { "name": "backdrop_path", "type": "string" },
          { "name": "release_date", "type": "string" },
          { "name": "vote_average", "type": "number" }
        ]
      }
    ]
  },
  "ui": {
    "pages": [
      {
        "route": "/dashboard",
        "name": "DashboardPage",
        "layout": "MainLayout",
        "components": [
          { "type": "Header", "props": { "title": "Evolua Movies" } },
          { "type": "MovieList", "props": { "data": "$Movie" } }
        ]
      },
      {
        "route": "/movie/[id]",
        "name": "MovieDetailsPage",
        "layout": "MainLayout",
        "components": [
          { "type": "Header", "props": { "title": "Movie Details", "backButton": true } },
          { "type": "MovieHero", "props": { "data": "$Movie" } },
          { "type": "MovieInfo", "props": { "data": "$Movie" } }
        ]
      }
    ],
    "components": [
      {
        "name": "MovieCard",
        "props": ["id", "title", "poster_path", "vote_average"],
        "style": "card-hover-effect"
      },
      {
        "name": "MovieHero",
        "props": ["backdrop_path", "title"],
        "style": "hero-large"
      }
    ]
  }
}
